#!/usr/bin/env bash
set -euo pipefail

APP_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
cd "$APP_DIR"

BUILD_DIR="${PACKETLENS_BUILD_DIR:-build-current}"

if [[ ! -x "$BUILD_DIR/packetlens" ]]; then
    cmake -S . -B "$BUILD_DIR"
    cmake --build "$BUILD_DIR"
fi

exec "$APP_DIR/$BUILD_DIR/packetlens" "$@"
